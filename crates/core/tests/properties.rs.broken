#![warn(clippy::pedantic)]
#![warn(clippy::nursery)]
#![forbid(unsafe_code)]

//! Property-based tests for core domain types using proptest.
//!
//! This module provides Arbitrary implementations for domain identifier types,
//! enabling property-based testing across the codebase.

use proptest::prelude::*;
use scp_core::domain::identifiers::{
    AbsolutePath, AgentId, BeadId, IdentifierError, SessionId, SessionName, TaskId, WorkspaceName,
};

// ============================================================================
// SessionName - valid session names
// ============================================================================

impl Arbitrary for SessionName {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_session_name_strategy()
    }
}

/// Strategy for generating valid SessionName values.
/// Rules: starts with letter, alphanumeric + hyphen + underscore, 1-63 chars.
fn valid_session_name_strategy() -> impl Strategy<Value = SessionName> {
    prop_oneof![
        // Single letter prefix
        "[a-zA-Z][a-zA-Z0-9_-]{0,62}",
        // Two letter prefix
        "[a-zA-Z][a-zA-Z0-9_-]{0,61}",
    ]
    .prop_map(|s| SessionName::parse(s).unwrap())
    .boxed()
}

/// Strategy for generating invalid SessionName values for testing validation.
fn invalid_session_name_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // Only whitespace
        Just("   ".to_string()),
        // Starts with number
        Just("123-session".to_string()),
        // Contains spaces
        Just("my session".to_string()),
        // Contains special chars
        Just("my.session".to_string()),
        // Too long
        (64..100u32).prop_map(|len| "a".repeat(len as usize)),
    ]
}

// ============================================================================
// AgentId - valid agent IDs
// ============================================================================

impl Arbitrary for AgentId {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_agent_id_strategy()
    }
}

/// Strategy for generating valid AgentId values.
/// Rules: alphanumeric + hyphen + underscore + dot + colon, 1-128 chars.
fn valid_agent_id_strategy() -> impl Strategy<Value = AgentId> {
    "[a-zA-Z0-9_.-]{1,128}"
        .prop_map(|s| AgentId::parse(s).unwrap())
        .boxed()
}

/// Strategy for generating invalid AgentId values.
fn invalid_agent_id_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // Contains spaces
        Just("agent 123".to_string()),
        // Contains slash
        Just("agent/123".to_string()),
        // Contains at sign
        Just("agent@123".to_string()),
    ]
}

// ============================================================================
// WorkspaceName - valid workspace names
// ============================================================================

impl Arbitrary for WorkspaceName {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_workspace_name_strategy()
    }
}

/// Strategy for generating valid WorkspaceName values.
/// Rules: no path separators or null bytes, 1-255 chars.
fn valid_workspace_name_strategy() -> impl Strategy<Value = WorkspaceName> {
    "[a-zA-Z0-9_-]{1,255}"
        .prop_filter_map("valid workspace name", |s| {
            if s.contains('/') || s.contains('\\') || s.contains('\0') {
                None
            } else {
                WorkspaceName::parse(s).ok()
            }
        })
        .boxed()
}

/// Strategy for generating invalid WorkspaceName values.
fn invalid_workspace_name_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // Contains forward slash
        Just("my/workspace".to_string()),
        // Contains backslash
        Just(r"my\workspace".to_string()),
        // Contains null byte
        "workspace\x00name".prop_map(String::from),
        // Too long
        (256..300u32).prop_map(|len| "a".repeat(len as usize)),
    ]
}

// ============================================================================
// TaskId / BeadId - valid task/bead IDs
// ============================================================================

impl Arbitrary for TaskId {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_task_id_strategy()
    }
}

impl Arbitrary for BeadId {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_task_id_strategy()
    }
}

/// Strategy for generating valid TaskId/BeadId values.
/// Rules: "bd-" prefix followed by hex characters.
fn valid_task_id_strategy() -> impl Strategy<Value = TaskId> {
    "bd-[a-fA-F0-9]{1,64}"
        .prop_map(|s| TaskId::parse(s).unwrap())
        .boxed()
}

/// Strategy for generating invalid TaskId values.
fn invalid_task_id_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // No prefix
        Just("abc123".to_string()),
        // Invalid prefix
        Just("ab-abc123".to_string()),
        // Contains non-hex chars
        Just("bd-xyz123".to_string()),
        // Contains special chars after prefix
        Just("bd-abc_123".to_string()),
    ]
}

// ============================================================================
// SessionId - valid session IDs
// ============================================================================

impl Arbitrary for SessionId {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_session_id_strategy()
    }
}

/// Strategy for generating valid SessionId values.
/// Rules: non-empty ASCII only.
fn valid_session_id_strategy() -> impl Strategy<Value = SessionId> {
    "[a-zA-Z0-9_-]{1,100}"
        .prop_map(|s| SessionId::parse(s).unwrap())
        .boxed()
}

/// Strategy for generating invalid SessionId values.
fn invalid_session_id_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // Non-ASCII
        "session-日本語".prop_map(String::from),
    ]
}

// ============================================================================
// AbsolutePath - valid absolute paths (Unix)
// ============================================================================

impl Arbitrary for AbsolutePath {
    type Parameters = ();
    type Strategy = BoxedStrategy<Self>;

    fn arbitrary_with(_args: Self::Parameters) -> Self::Strategy {
        valid_absolute_path_strategy()
    }
}

/// Strategy for generating valid AbsolutePath values on Unix.
/// Rules: starts with /, no null bytes.
fn valid_absolute_path_strategy() -> impl Strategy<Value = AbsolutePath> {
    prop::string::string_regex(r"/[a-zA-Z0-9_/-]*")
        .unwrap()
        .prop_filter_map("valid absolute path", |s| {
            if s.is_empty() || s.contains('\0') {
                None
            } else {
                AbsolutePath::parse(&s).ok()
            }
        })
        .boxed()
}

/// Strategy for generating invalid AbsolutePath values.
fn invalid_absolute_path_strategy() -> impl Strategy<Value = String> {
    prop_oneof![
        // Empty
        Just(String::new()),
        // Relative path
        Just("relative/path".to_string()),
        // Relative with current dir
        Just("./path".to_string()),
        // Null bytes
        "/path\x00name".prop_map(String::from),
    ]
}

// ============================================================================
// Property-based tests
// ============================================================================

proptest! {
    #[test]
    fn test_session_name_arbitrary_generates_valid(s in any::<SessionName>()) {
        let result = SessionName::parse(s.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid SessionName");
    }

    #[test]
    fn test_agent_id_arbitrary_generates_valid(a in any::<AgentId>()) {
        let result = AgentId::parse(a.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid AgentId");
    }

    #[test]
    fn test_workspace_name_arbitrary_generates_valid(w in any::<WorkspaceName>()) {
        let result = WorkspaceName::parse(w.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid WorkspaceName");
    }

    #[test]
    fn test_task_id_arbitrary_generates_valid(t in any::<TaskId>()) {
        let result = TaskId::parse(t.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid TaskId");
    }

    #[test]
    fn test_bead_id_arbitrary_generates_valid(b in any::<BeadId>()) {
        let result = BeadId::parse(b.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid BeadId");
    }

    #[test]
    fn test_session_id_arbitrary_generates_valid(s in any::<SessionId>()) {
        let result = SessionId::parse(s.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid SessionId");
    }

    #[test]
    fn test_absolute_path_arbitrary_generates_valid(p in any::<AbsolutePath>()) {
        let result = AbsolutePath::parse(p.as_str());
        assert!(result.is_ok(), "Arbitrary should only generate valid AbsolutePath");
    }

    // Round-trip tests: parse -> to_string -> parse should be identity
    #[test]
    fn test_session_name_roundtrip(s in any::<SessionName>()) {
        let parsed = SessionName::parse(s.as_str()).unwrap();
        let serialized = parsed.to_string();
        let reparsed = SessionName::parse(&serialized).unwrap();
        assert_eq!(parsed, reparsed);
    }

    #[test]
    fn test_task_id_roundtrip(t in any::<TaskId>()) {
        let parsed = TaskId::parse(t.as_str()).unwrap();
        let serialized = parsed.to_string();
        let reparsed = TaskId::parse(&serialized).unwrap();
        assert_eq!(parsed, reparsed);
    }

    #[test]
    fn test_absolute_path_roundtrip(p in any::<AbsolutePath>()) {
        let parsed = AbsolutePath::parse(p.as_str()).unwrap();
        let serialized = parsed.to_string();
        let reparsed = AbsolutePath::parse(&serialized).unwrap();
        assert_eq!(parsed, reparsed);
    }

    // Invalid inputs are rejected
    #[test]
    fn test_invalid_session_names_are_rejected(invalid in invalid_session_name_strategy()) {
        let result = SessionName::parse(&invalid);
        assert!(result.is_err(), "Invalid session name should be rejected: {:?}", invalid);
    }

    #[test]
    fn test_invalid_task_ids_are_rejected(invalid in invalid_task_id_strategy()) {
        let result = TaskId::parse(&invalid);
        assert!(result.is_err(), "Invalid task ID should be rejected: {:?}", invalid);
    }

    #[test]
    fn test_invalid_absolute_paths_are_rejected(invalid in invalid_absolute_path_strategy()) {
        let result = AbsolutePath::parse(&invalid);
        assert!(result.is_err(), "Invalid absolute path should be rejected: {:?}", invalid);
    }

    // Clone produces equal values
    #[test]
    fn test_session_name_clone(s in any::<SessionName>()) {
        let cloned = s.clone();
        assert_eq!(s, cloned);
    }

    #[test]
    fn test_agent_id_clone(a in any::<AgentId>()) {
        let cloned = a.clone();
        assert_eq!(a, cloned);
    }

    #[test]
    fn test_task_id_clone(t in any::<TaskId>()) {
        let cloned = t.clone();
        assert_eq!(t, cloned);
    }

    // Hash consistency
    #[test]
    fn test_session_name_hash(s in any::<SessionName>()) {
        use std::collections::hash_map::DefaultHasher;
        use std::hash::{Hash, Hasher};

        let mut hasher1 = DefaultHasher::new();
        let mut hasher2 = DefaultHasher::new();
        s.hash(&mut hasher1);
        s.clone().hash(&mut hasher2);
        assert_eq!(hasher1.finish(), hasher2.finish());
    }

    #[test]
    fn test_task_id_hash(t in any::<TaskId>()) {
        use std::collections::hash_map::DefaultHasher;
        use std::hash::{Hash, Hasher};

        let mut hasher1 = DefaultHasher::new();
        let mut hasher2 = DefaultHasher::new();
        t.hash(&mut hasher1);
        t.clone().hash(&mut hasher2);
        assert_eq!(hasher1.finish(), hasher2.finish());
    }

    // Display produces valid string
    #[test]
    fn test_session_name_display(s in any::<SessionName>()) {
        let display = s.to_string();
        assert!(!display.is_empty());
        assert_eq!(display, s.as_str());
    }

    #[test]
    fn test_workspace_name_display(w in any::<WorkspaceName>()) {
        let display = w.to_string();
        assert!(!display.is_empty());
        assert_eq!(display, w.as_str());
    }

    // AsRef produces correct slice
    #[test]
    fn test_session_name_as_ref(s in any::<SessionName>()) {
        let sref: &str = s.as_ref();
        assert_eq!(sref, s.as_str());
    }

    #[test]
    fn test_absolute_path_as_ref(p in any::<AbsolutePath>()) {
        let sref: &str = p.as_ref();
        assert_eq!(sref, p.as_str());
    }

    // into_string produces original value
    #[test]
    fn test_session_name_into_string(s in any::<SessionName>()) {
        let original = s.as_str().to_string();
        let into = s.into_string();
        assert_eq!(original, into);
    }

    #[test]
    fn test_task_id_into_string(t in any::<TaskId>()) {
        let original = t.as_str().to_string();
        let into = t.into_string();
        assert_eq!(original, into);
    }
}

// Additional tests with more iterations
mod stress {
    use super::*;

    proptest! {
        #[test]
        fn test_many_session_names(_ in 0..1000, s in any::<SessionName>()) {
            assert!(SessionName::parse(s.as_str()).is_ok());
        }

        #[test]
        fn test_many_task_ids(_ in 0..1000, t in any::<TaskId>()) {
            assert!(TaskId::parse(t.as_str()).is_ok());
        }

        #[test]
        fn test_many_absolute_paths(_ in 0..1000, p in any::<AbsolutePath>()) {
            assert!(AbsolutePath::parse(p.as_str()).is_ok());
        }
    }
}
